# 复制本文件为 .env 后按需修改（勿提交 .env）

# ---------- 批改 AI（推荐 Moonshot / Kimi）----------
# 在 https://platform.moonshot.cn/ 获取 API Key
MOONSHOT_API_KEY=sk-你的-moonshot-key
MOONSHOT_API_BASE=https://api.moonshot.cn/v1
MOONSHOT_VISION_MODEL=kimi-k2.6
MOONSHOT_TEXT_MODEL=kimi-k2.6
# MOONSHOT_TEMPERATURE=0.05
# MOONSHOT_MAX_TOKENS=8192
# MOONSHOT_TIMEOUT=120

# 未配置 MOONSHOT 时回退 DashScope（通义千问视觉）
# DASHSCOPE_API_KEY=sk-你的-dashscope-key
# DASHSCOPE_VL_MODEL=qwen-vl-max
# DASHSCOPE_TEXT_MODEL=qwen-plus

# π 助手智能问答（Agnes，与批改分离）— https://platform.agnes-ai.com/
AGNES_API_KEY=sk-你的-agnes-key
# AGNES_API_BASE=https://apihub.agnes-ai.com/v1
# AGNES_ASSISTANT_MODEL=agnes-2.0-flash
# ASSISTANT_LLM_MAX_ROUNDS=20
# ASSISTANT_LLM_MAX_ROUNDS_TEACHER=25

# 服务
FLASK_PORT=50003
FLASK_DEBUG=0
SECRET_KEY=请改为随机长字符串

# 演示登录（生产环境务必修改）
DEMO_ACCOUNT=13800138000
DEMO_PASSWORD=123456
GUARDIAN_DEMO_PASSPHRASE=HW-ALLOW
GRADING_MIN_GRADE=7

# 上传限制（字节，默认 15MB）
# MAX_UPLOAD_BYTES=15728640

# 令牌有效期（秒，默认 7 天）
# TOKEN_MAX_AGE_SECONDS=604800
